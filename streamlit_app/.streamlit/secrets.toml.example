# Copy this file to secrets.toml and fill in your values.
# secrets.toml is gitignored — never commit it.
#
# For local dev:   place at  streamlit_app/.streamlit/secrets.toml
# For Streamlit Cloud: paste the contents into App Settings → Secrets

# URL of your deployed FastAPI backend (Render, Railway, etc.)
# For local testing use: http://localhost:8000
BACKEND_URL = "https://your-app-name.onrender.com"
