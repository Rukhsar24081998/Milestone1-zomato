# Copy to .env — never commit .env (see .gitignore).

# Optional for Phase 0; required once the LLM client is implemented (Phase 3).
OPENAI_API_KEY=

# Hugging Face dataset for restaurant rows (Phase 1 ingestion).
ZOMATO_HF_DATASET=ManikaSaini/zomato-restaurant-recommendation
# Pin for repeatable runs; leave unset to use the dataset default revision.
# ZOMATO_HF_DATASET_REVISION=

# LLM defaults (Phase 3).
ZOMATO_LLM_PROVIDER=openai
ZOMATO_LLM_MODEL=gpt-4o-mini

# Phase 1: Parquet cache read by list_restaurants() after ingest (default: data/cache/restaurants.parquet).
# ZOMATO_RESTAURANT_CACHE_PATH=

# Phase 2: max rows after deterministic filter (before LLM). Default 50.
# ZOMATO_FILTER_TOP_K=
